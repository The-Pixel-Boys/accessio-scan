{
  "name": "accessio-scan",
  "version": "0.1.0",
  "description": "Open-source accessibility scanner. Runs axe-core against any URL and reports WCAG violations. MIT-licensed.",
  "keywords": [
    "accessibility",
    "a11y",
    "wcag",
    "axe-core",
    "playwright",
    "cli",
    "scanner",
    "sarif"
  ],
  "homepage": "https://github.com/The-Pixel-Boys/accessio-scan",
  "bugs": {
    "url": "https://github.com/The-Pixel-Boys/accessio-scan/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/The-Pixel-Boys/accessio-scan.git"
  },
  "license": "MIT",
  "author": "Accessio.AI <hello@accessio.ai> (https://accessio.ai)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "accessio-scan": "./dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage .turbo node_modules/.cache",
    "prepublishOnly": "npm run clean && npm run build && npm test"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.10.2",
    "axe-core": "^4.10.2",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "playwright": "^1.50.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^3.0.5",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
